{
  "name": "markdown-frontmatter-parser",
  "description": "A type-safe Markdown Frontmatter parser",
  "version": "1.2.0",
  "license": "MIT",
  "author": {
    "name": "Valerian Saliou",
    "email": "valerian@valeriansaliou.name",
    "url": "https://valeriansaliou.name/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/crisp-oss/node-markdown-frontmatter-parser"
  },
  "keywords": ["markdown", "frontmatter", "yaml", "toml", "json", "parser"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">= 18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
